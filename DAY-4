69. Sqrt(x)
class Solution {
public:
    int mySqrt(int x) {
        if (x==0 || x==1) {
            return x;
        }
    long i=1; 
    long j=x;
    
        while (i<=j) {
            long mid = (i+j)/2;
            long long sq= mid*mid;

            if(sq >x) {
                j= mid-1;
            } else if (sq < x) {
                i = mid+1;
            }else {
                return mid;
            }

        }
        return j;
    }
};
