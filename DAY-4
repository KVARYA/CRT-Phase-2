74. Search a 2D Matrix
class Solution {
public:
    bool searchMatrix(vector<vector<int>>& matrix, int target) {
        int m = matrix.size();
        int n = matrix[0].size();
        int low = 0, high=m*n-1;   

        while(low <= high) {
            int mid = (low+high)/2;
            int rIndex = mid/n;
            int cIndex = mid%n;
            if(target == matrix[rIndex][cIndex]) return true;
            if(target > matrix[rIndex][cIndex]) {
                low = mid+1;
            }else {
                high = mid-1;
            }
        }   
        return false;            
    }
};

