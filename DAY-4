875. Koko Eating Bananas
class Solution {
public:
    int minEatingSpeed(vector<int>& piles, int h) {
        int n = piles.size();
        int low = 1;
        int high = *max_element(piles.begin(), piles.end());

        while(low < high) {
            int mid = low + (high-low) /2;
            int k =0;
            for(int &i: piles) {
                k += (int)ceil((double)i/mid);
            }
            if(k <= h) {
                high = mid;
            }else {
                low = mid+1;
            }
        }
        return low;
    }
};
