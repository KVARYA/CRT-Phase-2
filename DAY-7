160. Intersection of Two Linked Lists
class Solution {
public:
    ListNode *getIntersectionNode(ListNode *headA, ListNode *headB) {
        unordered_set<ListNode* > set;
        while(headA) {
            set.insert(headA);
            headA=headA->next;
        }
        while(headB) {
            if(set.find(headB) != set.end()) {
                return headB;
            }
            headB = headB->next;
        }
        return NULL;
    }
};

