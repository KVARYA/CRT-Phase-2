2. Add Two Numbers
class Solution {
public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        int carry = 0;
        ListNode dummy;
        ListNode* ptr = &dummy;

        while(l1!= NULL || l2 != NULL || carry!=0) {
            int sum = carry;
            if(l1 != NULL) {
                sum += l1->val;
                l1 = l1->next;
            }
            if(l2 != NULL) {
                sum += l2->val;
                l2= l2->next;
            }
            carry = sum/10;
            sum = sum%10;
            ptr->next= new ListNode(sum);
            ptr = ptr->next;
        }
        return dummy.next;

    }
};

