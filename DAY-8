234. Palindrome Linked List
class Solution {
public:
    bool isPalindrome(ListNode* head) {
        if(head == NULL || head->next == NULL) return true;
        
        ListNode* temp = head;
        vector<int> arr;
        while(head) {
            arr.push_back(head->val);
            head= head->next;
        }
        int n = arr.size();
        int j = n-1;

        for(int i=0; i<n; i++) {
            if(arr[i] != arr[j--]) {
                 return false;
            }
        }
        head = temp;
        int i=0;
        while(head){
            head->val= arr[i++];
            head= head->next;
        }
        return true;
        
    }
};

