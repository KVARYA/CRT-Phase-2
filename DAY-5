2418. Sort the People
class Solution {
public:
    vector<string> sortPeople(vector<string>& names, vector<int>& heights) {
        int n = names.size();
        map<int, string,greater<int>> mp;
        for(int i =0; i<n; i++) {
            mp[heights[i]] = names[i];
        }
        vector<string> ans;
        for(auto &i : mp) {
            ans.push_back(i.second);
        }
        return ans;
    }
};
