509. Fibonacci Number
class Solution {
public:
    vector<int> dp = vector<int>(31, -1);  // initialize with -1

    int fib(int n) {
        if(n == 0 || n == 1) return n;
        if(dp[n] != -1) return dp[n];  // already calculated
        dp[n] = fib(n-1) + fib(n-2);   // store result
        return dp[n];
    }
};


