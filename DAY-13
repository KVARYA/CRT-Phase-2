198. House Robber
class Solution {
public:
    int rob(vector<int>& nums) {
        int prev = 0, curr =0;
        for(auto x: nums) {
            int temp = max(curr, prev + x);
            prev = curr;
            curr = temp;
        }
        return curr;
    }
};

